generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./custom.db"
}

model ScrapedPage {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  topic       String   // e.g. "NLP", "Data Mining", "Machine Learning"
  sectionCount Int     @default(0)
  imageCount  Int      @default(0)
  formulaCount Int     @default(0)
  childLinks  String   // JSON array of discovered links
  scrapedAt   DateTime @default(now())
  checksum    String   // hash of content for change detection

  images      ScrapedImage[]
  formulas    ScrapedFormula[]
  topicRel    Topic?        @relation(fields: [topic], references: [name])

  @@index([topic])
  @@index([url])
}

model ScrapedImage {
  id        String   @id @default(cuid())
  pageId    String
  url       String
  filePath  String   // local path where image is stored
  fileName  String
  order     Int
  width     Int      @default(0)
  height    Int      @default(0)
  alt       String?
  page      ScrapedPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model ScrapedFormula {
  id        String   @id @default(cuid())
  pageId    String
  latex     String
  rendered  String   // Unicode-rendered version
  order     Int
  page      ScrapedPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model Topic {
  id        String   @id @default(cuid())
  name      String   @unique
  startUrl  String
  depth     Int      @default(1)
  pageCount Int      @default(0)
  fileName  String?  // generated docx filename
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages     ScrapedPage[]
}